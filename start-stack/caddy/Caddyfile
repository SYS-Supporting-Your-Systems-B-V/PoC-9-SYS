{$PUBLIC_DOMAIN} {

  handle_path /nuts-oauth2/* {
    reverse_proxy nuts-node:8084
  }

  handle_path /notifiedpull/* {
    # Sender-side protected resource serving now goes through the dedicated gateway.
    # The gateway performs token introspection plus authorization-base / task / role checks
    # before proxying to the internal sender HAPI instance.
    reverse_proxy sender-bgz-gateway:8001
  }

  handle {
    reverse_proxy hapi-directory:8080
  }
  
  tls {
    dns cloudflare {env.CLOUDFLARE_API_TOKEN}
  }
}
