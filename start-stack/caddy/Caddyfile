{$PUBLIC_DOMAIN} {

  handle_path /nuts-oauth2/* {
    reverse_proxy nuts-node:8084
  }

#  handle_path /notifiedpull/* {
#    reverse_proxy hapi-notifiedpull-stu3:8082
#  }

  handle_path /notifiedpull/* {
    # NOTE: forward_auth requires a Caddy build with an auth_request/forward_auth plugin.
    # The standard introspection endpoint returns 200 even for inactive tokens, so in
    # production you should proxy to a small auth sidecar that returns 2xx only when
    # the token is valid.
    forward_auth nuts-node:8083 {
      uri /internal/auth/v2/accesstoken/introspect
      copy_headers Authorization
    }
    reverse_proxy hapi-notifiedpull-stu3:8082
  }

  handle {
    reverse_proxy hapi-directory:8080
  }
  
  tls {
    dns cloudflare {env.CLOUDFLARE_API_TOKEN}
  }
}
