{$PUBLIC_DOMAIN} {

  handle_path /nuts-oauth2/* {
    reverse_proxy nuts-node:8084
  }

  handle_path /notifiedpull/* {
    forward_auth nuts-node:8083 {
      uri /internal/auth/v2/accesstoken/introspect
      copy_headers Authorization
    }
    reverse_proxy hapi-notifiedpull-stu3:8082
  }

  handle {
    reverse_proxy hapi-directory:8080
  }

  tls internal
}
