# Enable optional services via Compose profiles.
# Example: COMPOSE_PROFILES=caddy
COMPOSE_PROFILES=

# Public base URLs shown by the HAPI tester UI.
# Local defaults point at the direct container ports.
# Override these on the server, for example:
# HAPI_DIRECTORY_PUBLIC_URL=https://mach2.disyepd.com/fhir
# HAPI_NOTIFIEDPULL_PUBLIC_URL=https://mach2.disyepd.com/notifiedpull/fhir
HAPI_UPDATE_CLIENT_PRIVATE_URL=http://localhost:8081/fhir
HAPI_DIRECTORY_PUBLIC_URL=http://localhost:8080/fhir
HAPI_NOTIFIEDPULL_PUBLIC_URL=http://localhost:8082/fhir/notifiedpull/
