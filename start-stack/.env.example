# Enable optional services via Compose profiles.
# Example: COMPOSE_PROFILES=caddy
COMPOSE_PROFILES=caddy
CADDYFILE_NAME=Caddyfile.local
PUBLIC_DOMAIN=mach2.disyepd.com
# On the real host, switch CADDYFILE_NAME to Caddyfile and provide a valid Cloudflare API token.
# The local Caddyfile uses `tls internal`, so browsers will trust it only after you trust Caddy's local CA.

# `PUBLIC_DOMAIN` drives the Caddy host, the Docker network alias, the Nuts public base URL,
# and the public URLs shown by the HAPI tester UI for directory and notifiedpull.
HAPI_UPDATE_CLIENT_PRIVATE_URL=http://localhost:8081/fhir
